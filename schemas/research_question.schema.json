{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research_question.schema.json",
  "title": "AudiologyBench research-derived question",
  "description": "One record from data/research_questions.jsonl.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "tier",
    "question_type",
    "response_format",
    "question",
    "reference_answer",
    "source_id",
    "source_item_id",
    "source_title",
    "domain",
    "theme",
    "difficulty"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RES-[0-9]{6}$"
    },
    "tier": {
      "const": "research"
    },
    "question_type": {
      "enum": ["MCQ", "TF", "SA"]
    },
    "response_format": {
      "enum": ["single_choice", "binary", "short_answer"]
    },
    "question": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "options": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {"$ref": "#/$defs/optionA"},
        {"$ref": "#/$defs/optionB"},
        {"$ref": "#/$defs/optionC"},
        {"$ref": "#/$defs/optionD"}
      ],
      "items": false
    },
    "reference_answer": {
      "$ref": "#/$defs/stringOrComponentList"
    },
    "source_id": {
      "type": "string",
      "pattern": "^RES-SRC-[0-9]{4}$",
      "description": "Foreign key to metadata/sources.csv; it does not imply redistribution clearance."
    },
    "source_item_id": {
      "type": "integer",
      "minimum": 1
    },
    "source_title": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "domain": {
      "const": "Audiology/Hearing Sciences"
    },
    "theme": {
      "enum": [
        "Clinical Audiology",
        "Hearing Technology",
        "Psychoacoustics",
        "Pediatric Audiology"
      ]
    },
    "difficulty": {
      "enum": ["Basic", "Intermediate", "Advanced"]
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "answerComponentList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "description": "Jointly required answer components, not interchangeable alternatives. Frozen singleton arrays remain arrays."
    },
    "stringOrComponentList": {
      "oneOf": [
        {"$ref": "#/$defs/nonEmptyString"},
        {"$ref": "#/$defs/answerComponentList"}
      ]
    },
    "optionBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "text"],
      "properties": {
        "label": {"type": "string"},
        "text": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "optionA": {
      "allOf": [
        {"$ref": "#/$defs/optionBase"},
        {"properties": {"label": {"const": "A"}}}
      ]
    },
    "optionB": {
      "allOf": [
        {"$ref": "#/$defs/optionBase"},
        {"properties": {"label": {"const": "B"}}}
      ]
    },
    "optionC": {
      "allOf": [
        {"$ref": "#/$defs/optionBase"},
        {"properties": {"label": {"const": "C"}}}
      ]
    },
    "optionD": {
      "allOf": [
        {"$ref": "#/$defs/optionBase"},
        {"properties": {"label": {"const": "D"}}}
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"question_type": {"const": "MCQ"}},
        "required": ["question_type"]
      },
      "then": {
        "required": ["options"],
        "properties": {
          "response_format": {"const": "single_choice"},
          "reference_answer": {
            "type": "string",
            "pattern": "^[A-D]$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {"question_type": {"const": "TF"}},
        "required": ["question_type"]
      },
      "then": {
        "not": {"required": ["options"]},
        "properties": {
          "response_format": {"const": "binary"},
          "reference_answer": {"enum": ["True", "False"]}
        }
      }
    },
    {
      "if": {
        "properties": {"question_type": {"const": "SA"}},
        "required": ["question_type"]
      },
      "then": {
        "not": {"required": ["options"]},
        "properties": {
          "response_format": {"const": "short_answer"},
          "reference_answer": {"$ref": "#/$defs/stringOrComponentList"}
        }
      }
    }
  ]
}
